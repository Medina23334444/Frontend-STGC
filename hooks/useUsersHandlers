// hooks/useUsersHandlers.ts
import { useCallback } from 'react';
import { RegisterFormInputs } from '@/schemas/user.schema';
import { useUsersData } from './useUsersData';

// ✅ Definir tipos FUERA de la función
type CreateUserHandler = (datos: RegisterFormInputs) => Promise<void>;
type EditUserHandler = (userId: string, datos: RegisterFormInputs) => Promise<void>;
type DeleteUserHandler = (userId: string) => Promise<void>;

/**
 * Hook especializado en handlers/acciones de usuarios
 * Responsabilidades:
 * - Manejar creación de usuarios
 * - Manejar edición de usuarios
 * - Manejar eliminación de usuarios
 * - Abstraer la lógica de negocio
 */
export function useUsersHandlers() {
  const { createUser, updateUser, deleteUser } = useUsersData();

  // Handler para crear usuario
  const handleCreateUser = useCallback<CreateUserHandler>(async (datos) => {
    try {
      await createUser(datos);
    } catch (error) {
      console.error('Error creando usuario:', error);
      throw error;
    }
  }, [createUser]);

  // Handler para editar usuario
  const handleEditUser = useCallback<EditUserHandler>(async (userId, datos) => {
    try {
      await updateUser(userId, datos);
    } catch (error) {
      console.error('Error editando usuario:', error);
      throw error;
    }
  }, [updateUser]);

  // Handler para eliminar usuario
  const handleDeleteUser = useCallback<DeleteUserHandler>(async (userId) => {
    try {
      await deleteUser(userId);
    } catch (error) {
      console.error('Error eliminando usuario:', error);
      throw error;
    }
  }, [deleteUser]);

  return {
    handleCreateUser,
    handleEditUser,
    handleDeleteUser,
  };
}